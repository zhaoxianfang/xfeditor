{
  "name": "xf_editor",
  "version": "1.17.20",
  "description": "开源可嵌入 Markdown 在线编辑器 - 基于 pandao/editor.md 的改进增强版 | Open source embeddable online Markdown editor (improved fork of pandao/editor.md)",
  "directories": {
    "example": "examples",
    "test": "tests"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:js": "uglifyjs src/xf_editor.js -o xf_editor.min.js -c -m",
    "build:amd": "uglifyjs xf_editor.amd.js -o xf_editor.amd.min.js -c -m",
    "build:css": "cleancss css/xf_editor.css -o css/xf_editor.min.css && cleancss css/xf_editor.preview.css -o css/xf_editor.preview.min.css && cleancss css/xf_editor.logo.css -o css/xf_editor.logo.min.css"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zhaoxianfang/xfeditor.git"
  },
  "keywords": [
    "xf_editor",
    "markdown",
    "editor",
    "xfEditor",
    "xf-editor",
    "echarts",
    "katex",
    "wysiwyg",
    "markdown-editor",
    "hanzi",
    "pinyin",
    "javascript"
  ],
  "author": "yoc,zhaoxianfang",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zhaoxianfang/xfeditor/issues"
  },
  "homepage": "https://github.com/zhaoxianfang/xfeditor",
  "devDependencies": {
    "dateformatter": "^0.1.0",
    "gulp": "^3.8.11",
    "gulp-concat": "^2.4.2",
    "gulp-header": "^1.2.2",
    "gulp-jshint": "^1.9.0",
    "gulp-minify-css": "^0.4.4",
    "gulp-notify": "^2.1.0",
    "gulp-rename": "^1.2.0",
    "gulp-replace": "^0.5.3",
    "gulp-ruby-sass": "^1.0.1",
    "gulp-uglifyjs": "^0.6.1",
    "gulp-util": "^3.0.1",
    "sass": "^1.100.0",
    "uglify-js": "^3.19.3"
  },
  "dependencies": {
    "clean-css-cli": "^5.6.3",
    "diff-match-patch": "^1.0.5"
  }
}
