{
  "name": "editor.md",
  "version": "1.10.0",
  "description": "开源可嵌入 Markdown 在线编辑器 - 基于 pandao/editor.md 的改进增强版 | Open source embeddable online Markdown editor (improved fork of pandao/editor.md)",
  "directories": {
    "example": "examples",
    "test": "tests"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:js": "uglifyjs src/editormd.js -o editormd.min.js -c -m",
    "build:amd": "uglifyjs editormd.amd.js -o editormd.amd.min.js -c -m",
    "build:css": "cleancss css/editormd.css -o css/editormd.min.css && cleancss css/editormd.preview.css -o css/editormd.preview.min.css && cleancss css/editormd.logo.css -o css/editormd.logo.min.css"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zhaoxianfang/editor.git"
  },
  "keywords": [
    "editor.md",
    "markdown",
    "editor",
    "echarts",
    "katex",
    "wysiwyg",
    "markdown-editor",
    "hanzi",
    "javascript"
  ],
  "author": "yoc,zhaoxianfang",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zhaoxianfang/editor/issues"
  },
  "homepage": "https://github.com/zhaoxianfang/editor",
  "devDependencies": {
    "dateformatter": "^0.1.0",
    "gulp": "^3.8.11",
    "gulp-concat": "^2.4.2",
    "gulp-header": "^1.2.2",
    "gulp-jshint": "^1.9.0",
    "gulp-minify-css": "^0.4.4",
    "gulp-notify": "^2.1.0",
    "gulp-rename": "^1.2.0",
    "gulp-replace": "^0.5.3",
    "gulp-ruby-sass": "^1.0.1",
    "gulp-uglifyjs": "^0.6.1",
    "gulp-util": "^3.0.1",
    "sass": "^1.100.0",
    "uglify-js": "^3.19.3"
  },
  "dependencies": {
    "clean-css-cli": "^5.6.3",
    "diff-match-patch": "^1.0.5"
  }
}
